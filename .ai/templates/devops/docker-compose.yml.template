version: '3.8'

services:
  # Primary Database (MongoDB / Postgres / MySQL)
  # [DB_SERVICE_PLACEHOLDER]

  # Cache & Event Queue (Only if Redis Caching is enabled)
  redis:
    image: redis:7.0-alpine
    container_name: saas-redis
    ports:
      - "6379:6379"
    restart: always

  # Backend App Container (Optional)
  backend:
    build:
      context: ./codebase/backend
      dockerfile: Dockerfile
    container_name: saas-backend
    ports:
      - "3001:3001"
    environment:
      - NODE_ENV=production
      - PORT=3001
      - DATABASE_URL=${DATABASE_URL}
      - MONGODB_URI=${MONGODB_URI}
      - REDIS_URL=redis://redis:6379
      - JWT_SECRET=${JWT_SECRET}
    depends_on:
      - redis
    restart: always

  # Frontend App Container (Optional)
  frontend:
    build:
      context: ./codebase/frontend
      dockerfile: Dockerfile
    container_name: saas-frontend
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
      - NEXT_PUBLIC_API_URL=http://localhost:3001
    depends_on:
      - backend
    restart: always
